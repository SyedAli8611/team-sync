{
  "name": "teamsync",
  "version": "1.0.0",
  "description": "TeamSync - Internal Project Management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:reset": "node -e \"const db=require('better-sqlite3')('./teamsync.db');['comments','activity','standups','tasks'].forEach(t=>{db.prepare('DELETE FROM '+t).run();console.log('cleared:',t)});console.log('✅ DB reset done')\"",
    "db:cli": "node dbcli.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
